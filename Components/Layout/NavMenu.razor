@using HRMS.Services
@using HRMS.Models
@inject LanguageService Lang
@inject IUserService UserService
@implements IDisposable

<div class="top-row px-4 navbar navbar-light">
    <a class="navbar-brand d-flex align-items-center" href="">
        <img src="images/logo.png" alt="Logo" class="me-2 rounded-2 shadow-sm" style="height: 32px; width: 32px; object-fit: contain;" />
        <span class="fw-bold fs-5" style="letter-spacing: -0.5px;">HRMS</span>
    </a>
</div>

<div class="nav-scrollable mt-3">
    <nav class="nav flex-column">
        @foreach (var item in RootMenus)
        {
            var children = GetChildren(item.MenuCode).ToList();
            var displayName = Lang.IsRtl ? item.MenuNameAr : item.MenuNameEn;
            var href = string.IsNullOrEmpty(item.Href) || item.Href == "#" ? null : "/" + item.Href.TrimStart('/');

            @if (children.Count == 0)
            {
                var isHome = string.IsNullOrEmpty(href) || href == "/";
                <NavLink class="nav-link" href="@(href ?? "/")" Match="@(isHome ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                    <UiIcon Name="@item.Icon" />
                    <span>@displayName</span>
                </NavLink>
            }
            else
            {
                <div class="nav-category">
                    @displayName
                </div>
                @foreach (var child in children)
                {
                    var childName = Lang.IsRtl ? child.MenuNameAr : child.MenuNameEn;
                    var childHref = "/" + child.Href.TrimStart('/');
                    <NavLink class="nav-link" href="@childHref">
                        <UiIcon Name="@child.Icon" />
                        <span>@childName</span>
                    </NavLink>
                }
            }
        }
    </nav>
</div>

@code {
    private IEnumerable<Menu> RootMenus => UserService.Menus.Where(m => string.IsNullOrEmpty(m.ParentMenuCode));

    private IEnumerable<Menu> GetChildren(string parentCode) =>
        UserService.Menus.Where(m => m.ParentMenuCode == parentCode);

    protected override void OnInitialized()
    {
        UserService.OnRoleChanged += StateHasChanged;
    }

    public void Dispose()
    {
        UserService.OnRoleChanged -= StateHasChanged;
    }
}
