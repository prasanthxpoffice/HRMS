@using Microsoft.AspNetCore.Components

<svg class="bi-icon @CssClass" width="@Size" height="@Size" fill="currentColor" aria-hidden="true" @attributes="AdditionalAttributes">
    <use href="/lib/bootstrap-icons/bootstrap-icons.svg#@IconName" />
</svg>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string Size { get; set; } = "1em";
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private string IconName => Name.StartsWith("bi-") ? Name.Substring(3) : Name;
}
