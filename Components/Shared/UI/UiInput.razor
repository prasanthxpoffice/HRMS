@using HRMS.Components.Shared.UI
@inherits UiBase

<div class="mb-3 position-relative">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="small-label mb-1 d-block">@Label</label>
    }
    <div class="input-icon-wrapper position-relative w-100">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <UiIcon Name="@Icon" CssClass="position-absolute top-50 translate-middle-y text-muted small" 
                    style="@(Lang.IsRtl ? "right: 1rem;" : "left: 1rem;")" />
        }
        <input id="@Id" 
               type="@Type"
               class="form-control input-ui @(Lang.IsRtl ? "text-end" : "text-start") @(string.IsNullOrEmpty(Icon) ? "" : (Lang.IsRtl ? "pe-5" : "ps-5")) @CssClass" 
               value="@Value" 
               @oninput="OnInput"
               placeholder="@Placeholder"
               disabled="@Disabled"
               aria-label="@AriaLabel" />
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString();
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string AriaLabel { get; set; } = "";
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool IsRtl { get; set; } = false; // Kept for overrides but Lang.IsRtl used by default

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        await ValueChanged.InvokeAsync(Value);
    }
}
