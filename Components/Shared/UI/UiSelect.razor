@typeparam TValue

<div class="@(NoMargin ? "" : "mb-3")">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="small-label mb-1 d-block">@Label</label>
    }
    <select class="input-ui w-100 @CssClass" 
            style="@Style"
            value="@(Value?.ToString() ?? DefaultValue?.ToString() ?? "")" 
            @onchange="HandleChange"
            disabled="@Disabled"
            @attributes="AdditionalAttributes">
            
        @if (!string.IsNullOrEmpty(Placeholder))
        {
            <option value="@(DefaultValue?.ToString() ?? "")" disabled="@DisablePlaceholder" selected="@(Value == null || Value.ToString() == DefaultValue?.ToString())">@Placeholder</option>
        }
        
        @if (Items != null)
        {
            @foreach (var item in Items)
            {
                <option value="@item.Id">@item.Name</option>
            }
        }
        
        @ChildContent
    </select>
</div>

@code {
    [Parameter] public bool NoMargin { get; set; } = false;
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }
    
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string Style { get; set; } = "";
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Generics Upgrade Properties
    [Parameter] public IEnumerable<HRMS.Models.Shared.LookupItem>? Items { get; set; }
    [Parameter] public TValue? DefaultValue { get; set; }
    [Parameter] public bool DisablePlaceholder { get; set; } = true;

    private async Task HandleChange(ChangeEventArgs e)
    {
        var strValue = e.Value?.ToString();
        TValue? parsedValue = default;

        if (!string.IsNullOrEmpty(strValue) && strValue != DefaultValue?.ToString())
        {
            var targetType = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);
            
            try
            {
                if (targetType == typeof(int))
                {
                    parsedValue = (TValue)(object)int.Parse(strValue);
                }
                else if (targetType == typeof(string))
                {
                    parsedValue = (TValue)(object)strValue;
                }
                else
                {
                    parsedValue = (TValue)Convert.ChangeType(strValue, targetType);
                }
            }
            catch
            {
                parsedValue = default;
            }
        }

        Value = parsedValue;
        await ValueChanged.InvokeAsync(parsedValue);
    }
}
