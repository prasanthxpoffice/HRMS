@using Microsoft.AspNetCore.Components

<div class="page-header d-flex align-items-end justify-content-between mb-4">
    <div>
        <h1 class="header-title mb-0">@Title</h1>
        @if (!string.IsNullOrEmpty(Description))
        {
            <div class="header-subtitle mt-1 text-muted small">
                @if (!string.IsNullOrEmpty(Icon))
                {
                    <UiIcon Name="@Icon" CssClass="me-1" />
                }
                @Description
            </div>
        }
    </div>
    @if (ButtonContent != null)
    {
        <div class="page-header-actions">
            @ButtonContent
        </div>
    }
    else if (!string.IsNullOrEmpty(ButtonText))
    {
        <div class="page-header-actions">
            <UiButton Icon="bi-plus-lg" OnClick="OnButtonClick">@ButtonText</UiButton>
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "bi-info-circle";
    [Parameter] public string? ButtonText { get; set; }
    [Parameter] public EventCallback OnButtonClick { get; set; }
    [Parameter] public RenderFragment? ButtonContent { get; set; }
}
