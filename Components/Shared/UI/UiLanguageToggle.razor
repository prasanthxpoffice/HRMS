@using HRMS.Services
@inject LanguageService Lang
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav

<div class="language-toggle">
    <button class="btn-language-toggle d-flex align-items-center" @onclick="ToggleLanguage">
        <i class="bi bi-globe2 me-1"></i>
        <span>@(Lang.IsRtl ? "English" : "العربية")</span>
    </button>
</div>

@code {
    private async Task ToggleLanguage()
    {
        var targetLanguage = Lang.IsRtl ? "en-US" : "ar-AE";
        await ApplyLanguage(targetLanguage);
    }

    private async Task ApplyLanguage(string value)
    {
        if (!string.IsNullOrEmpty(value))
        {
            var cookieValue = $"c={value}|uic={value}";
            await JSRuntime.InvokeVoidAsync("cultureHelper.setCookie", ".AspNetCore.Culture", cookieValue, 365);
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
    }
}
