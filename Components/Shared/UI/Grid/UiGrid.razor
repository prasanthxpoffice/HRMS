@namespace HRMS.Components.Shared.UI.Grid
@inherits UiBase
@typeparam TItem
@using System.Reflection
@using System.Globalization

<div class="card-hrms overflow-hidden">
    @if (ShowHeader)
    {
        <div class="px-3 py-2 border-bottom bg-light bg-opacity-10">
            <div class="row align-items-center g-2">
                <div class="col">
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(Icon))
                        {
                            <UiIcon Name="@Icon" CssClass="text-primary opacity-75" Size="0.9rem" />
                        }
                        @if (!string.IsNullOrEmpty(Title))
                        {
                            <div class="small-label opacity-75 fw-bold text-uppercase" style="letter-spacing: 0.05em;">@Title</div>
                        }
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d-flex gap-2 align-items-center">
                        @if (ShowDeleteButton && SelectedItems.Any())
                        {
                            <UiButton Type="danger" Icon="bi-trash3" OnClick="HandleDeleteSelected" CssClass="btn-sm">
                                @Res.DeleteSelected (@SelectedItems.Count)
                            </UiButton>
                        }
                        @if (ShowAddButton)
                        {
                            <UiButton Icon="bi-plus-lg" OnClick="OnAddClick" CssClass="btn-sm">
                                @(string.IsNullOrEmpty(AddButtonText) ? Res.Add : AddButtonText)
                            </UiButton>
                        }
                        @HeaderContent
                    </div>
                </div>
            </div>
        </div>
    }
    
    <div class="table-responsive">
        <table class="table-hrms">
            <thead>
                <tr>
                    @if (ShowSelection)
                    {
                        <th style="width: 40px; text-align: center;">
                            <input type="checkbox" class="form-check-input" 
                                   checked="@IsAllSelected" 
                                   @onchange="ToggleSelectAll" />
                        </th>
                    }
                    @foreach (var col in Columns)
                    {
                        <th class="@(col.Sortable && !string.IsNullOrEmpty(col.FieldName) ? "ui-grid-cursor-pointer user-select-none" : "")" 
                            style="@(_sortField == col.FieldName ? "background-color: #f0f7ff;" : "")"
                            @onclick="() => HandleSort(col)">
                            <div class="d-flex align-items-center gap-1">
                                <span>@col.Title</span>
                                @if (col.Sortable && !string.IsNullOrEmpty(col.FieldName))
                                {
                                    <div class="d-flex flex-column lh-1" style="font-size: 0.6rem;">
                                        <i class="bi bi-caret-up-fill @(_sortField == col.FieldName && !_sortDescending ? "text-primary" : "text-muted opacity-50")"></i>
                                        <i class="bi bi-caret-down-fill @(_sortField == col.FieldName && _sortDescending ? "text-primary" : "text-muted opacity-50")" style="margin-top: -3px;"></i>
                                    </div>
                                }
                            </div>
                        </th>
                    }
                </tr>
                <tr class="filter-row">
                    @if (ShowSelection)
                    {
                        <td></td>
                    }
                    @foreach (var col in Columns)
                    {
                        <td>
                            @if (!string.IsNullOrEmpty(col.FieldName))
                            {
                                @switch (col.FilterType)
                                {
                                    case UiGridFilterType.Dropdown:
                                        <select class="input-hrms py-1 small" 
                                                value="@GetFilterValue(col.FieldName)" 
                                                @onchange="(e) => SetFilterValue(col.FieldName, e.Value?.ToString())">
                                            <option value="">@Res.All</option>
                                            @foreach (var val in GetDistinctValues(col.FieldName))
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        </select>
                                        break;
                                    case UiGridFilterType.Date:
                                        <input type="date" class="input-hrms py-1 small" 
                                               value="@GetFilterValue(col.FieldName)" 
                                               @onchange="(e) => SetFilterValue(col.FieldName, e.Value?.ToString())" />
                                        break;
                                    default:
                                        <input type="text" class="input-hrms py-1 small" 
                                               placeholder="@Res.Search..." 
                                               value="@GetFilterValue(col.FieldName)" 
                                               @oninput="(e) => SetFilterValue(col.FieldName, e.Value?.ToString())" />
                                        break;
                                }
                            }
                        </td>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Loading)
                {
                    <tr>
                        <td colspan="@(Columns.Count + (ShowSelection ? 1 : 0))" class="text-center py-5">
                            <div class="spinner-border text-primary opacity-50" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <div class="mt-2 text-muted small">@Res.Search...</div>
                        </td>
                    </tr>
                }
                else if (PagedItems != null && PagedItems.Any())
                {
                    @foreach (var item in PagedItems)
                    {
                        <tr class="@(SelectedItems.Contains(item) ? "ui-grid-table-selection" : "")">
                            @if (ShowSelection)
                            {
                                <td style="text-align: center;">
                                    <input type="checkbox" class="form-check-input" 
                                           checked="@SelectedItems.Contains(item)" 
                                           @onchange="() => ToggleSelection(item)" />
                                </td>
                            }
                            @foreach (var col in Columns)
                            {
                                <td>
                                    @if (col.Template != null)
                                    {
                                        @col.Template(item)
                                    }
                                    else
                                    {
                                        var val = GetPropertyValue(item, col.FieldName);
                                        if (col.FilterType == UiGridFilterType.Date && val is DateTime dt)
                                        {
                                            @dt.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            @val
                                        }
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(Columns.Count + (ShowSelection ? 1 : 0))" class="text-center py-5">
                            <span class="text-muted small">@Res.NoRecordsFound</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="px-3 py-2 border-top bg-light bg-opacity-10">
        <div class="row align-items-center g-3">
            <div class="col-12 col-md text-muted small text-center text-md-start">
                @Res.GetString("ShowingXToYOfZ", (CurrentPage - 1) * PageSize + 1, Math.Min(CurrentPage * PageSize, TotalItems), TotalItems)
            </div>
            
            <div class="col-12 col-md-auto">
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted">@Res.Rows</span>
                        <select class="form-select form-select-sm border-0 bg-white shadow-sm" style="width: 70px;" 
                                value="@PageSize" @onchange="OnPageSizeChanged">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0 gap-1">
                            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                <button class="page-link ui-grid-page-link border-0 rounded shadow-sm" @onclick="() => GoToPage(CurrentPage - 1)" 
                                        aria-label="@Res.Previous">
                                    <i class="bi @(Lang.IsRtl ? "bi-chevron-right" : "bi-chevron-left")"></i>
                                </button>
                            </li>
                            
                            @foreach (var p in GetPageNumbers())
                            {
                                if (p == -1)
                                {
                                    <li class="page-item disabled"><span class="page-link ui-grid-page-link border-0 bg-transparent">...</span></li>
                                }
                                else
                                {
                                    <li class="page-item @(CurrentPage == p ? "active" : "")">
                                        <button class="page-link ui-grid-page-link border-0 rounded shadow-sm" @onclick="() => GoToPage(p)">@p</button>
                                    </li>
                                }
                            }

                            <li class="page-item @(CurrentPage == (TotalPages == 0 ? 1 : TotalPages) ? "disabled" : "")">
                                <button class="page-link ui-grid-page-link border-0 rounded shadow-sm" @onclick="() => GoToPage(CurrentPage + 1)"
                                        aria-label="@Res.Next">
                                    <i class="bi @(Lang.IsRtl ? "bi-chevron-left" : "bi-chevron-right")"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<UiModal Show="_showConfirmModal" Title="@Res.DeleteConfirmTitle" OnClose="() => _showConfirmModal = false">
    <Body>
        <div class="text-center py-3">
            <div class="mb-3">
                <UiIcon Name="bi-exclamation-triangle" CssClass="text-warning display-4" />
            </div>
            <p class="mb-0">
                @if (_itemPendingDelete != null)
                {
                    @Res.DeleteConfirmMessage
                }
                else
                {
                    @Res.GetString("BulkDeleteConfirmMessage", SelectedItems.Count)
                }
            </p>
        </div>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="() => _showConfirmModal = false">@Res.Cancel</UiButton>
        <UiButton Type="danger" OnClick="ConfirmDelete">@Res.Delete</UiButton>
    </Footer>
</UiModal>


