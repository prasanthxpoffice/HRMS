@inherits UiBase
@typeparam TItem
@using System.Reflection
@using System.Globalization
@inject IDataService DataService
@inject INotificationService NotificationService

<div class="card-hrms overflow-hidden">
    @if (ShowHeader)
    {
        <div class="px-3 py-2 border-bottom bg-light bg-opacity-10">
            <div class="row align-items-center g-2">
                <div class="col">
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(Icon))
                        {
                            <UiIcon Name="@Icon" CssClass="text-primary opacity-75" Size="0.9rem" />
                        }
                        @if (!string.IsNullOrEmpty(Title))
                        {
                            <div class="small-label opacity-75 fw-bold text-uppercase" style="letter-spacing: 0.05em;">@Title</div>
                        }
                    </div>
                </div>
                <div class="col-auto">
                    <div class="d-flex gap-2 align-items-center">
                        @if (ShowDeleteButton && SelectedItems.Any())
                        {
                            <UiButton Type="danger" Icon="bi-trash3" OnClick="HandleDeleteSelected" CssClass="btn-sm">
                                @Res.DeleteSelected (@SelectedItems.Count)
                            </UiButton>
                        }
                        @if (ShowAddButton)
                        {
                            <UiButton Icon="bi-plus-lg" OnClick="OnAddClick" CssClass="btn-sm">
                                @(string.IsNullOrEmpty(AddButtonText) ? Res.Add : AddButtonText)
                            </UiButton>
                        }
                        @HeaderContent
                    </div>
                </div>
            </div>
        </div>
    }
    
    <div class="table-responsive">
        <table class="table-hrms">
            <thead>
                <tr>
                    @if (ShowSelection)
                    {
                        <th style="width: 40px; text-align: center;">
                            <input type="checkbox" class="form-check-input" 
                                   checked="@IsAllSelected" 
                                   @onchange="ToggleSelectAll" />
                        </th>
                    }
                    @foreach (var col in Columns)
                    {
                        <th class="@(col.Sortable && !string.IsNullOrEmpty(col.FieldName) ? "cursor-pointer user-select-none" : "")" 
                            style="@(_sortField == col.FieldName ? "background-color: #f0f7ff;" : "")"
                            @onclick="() => HandleSort(col)">
                            <div class="d-flex align-items-center gap-1">
                                <span>@col.Title</span>
                                @if (col.Sortable && !string.IsNullOrEmpty(col.FieldName))
                                {
                                    <div class="d-flex flex-column lh-1" style="font-size: 0.6rem;">
                                        <i class="bi bi-caret-up-fill @(_sortField == col.FieldName && !_sortDescending ? "text-primary" : "text-muted opacity-50")"></i>
                                        <i class="bi bi-caret-down-fill @(_sortField == col.FieldName && _sortDescending ? "text-primary" : "text-muted opacity-50")" style="margin-top: -3px;"></i>
                                    </div>
                                }
                            </div>
                        </th>
                    }
                </tr>
                <tr class="filter-row">
                    @if (ShowSelection)
                    {
                        <td></td>
                    }
                    @foreach (var col in Columns)
                    {
                        <td>
                            @if (!string.IsNullOrEmpty(col.FieldName))
                            {
                                @switch (col.FilterType)
                                {
                                    case UiGridFilterType.Dropdown:
                                        <select class="input-hrms py-1 small" 
                                                value="@GetFilterValue(col.FieldName)" 
                                                @onchange="(e) => SetFilterValue(col.FieldName, e.Value?.ToString())">
                                            <option value="">@Res.All</option>
                                            @foreach (var val in GetDistinctValues(col.FieldName))
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        </select>
                                        break;
                                    case UiGridFilterType.Date:
                                        <input type="date" class="input-hrms py-1 small" 
                                               value="@GetFilterValue(col.FieldName)" 
                                               @onchange="(e) => SetFilterValue(col.FieldName, e.Value?.ToString())" />
                                        break;
                                    default:
                                        <input type="text" class="input-hrms py-1 small" 
                                               placeholder="@Res.Search..." 
                                               value="@GetFilterValue(col.FieldName)" 
                                               @oninput="(e) => SetFilterValue(col.FieldName, e.Value?.ToString())" />
                                        break;
                                }
                            }
                        </td>
                    }
                </tr>
            </thead>
            <tbody>
                @if (PagedItems != null && PagedItems.Any())
                {
                    @foreach (var item in PagedItems)
                    {
                        <tr class="@(SelectedItems.Contains(item) ? "table-active-selection" : "")">
                            @if (ShowSelection)
                            {
                                <td style="text-align: center;">
                                    <input type="checkbox" class="form-check-input" 
                                           checked="@SelectedItems.Contains(item)" 
                                           @onchange="() => ToggleSelection(item)" />
                                </td>
                            }
                            @foreach (var col in Columns)
                            {
                                <td>
                                    @if (col.Template != null)
                                    {
                                        @col.Template(item)
                                    }
                                    else
                                    {
                                        var val = GetPropertyValue(item, col.FieldName);
                                        if (col.FilterType == UiGridFilterType.Date && val is DateTime dt)
                                        {
                                            @dt.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            @val
                                        }
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(Columns.Count + (ShowSelection ? 1 : 0))" class="text-center py-5">
                            <span class="text-muted small">@Res.NoRecordsFound</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="px-3 py-2 border-top bg-light bg-opacity-10">
        <div class="row align-items-center g-3">
            <div class="col-12 col-md text-muted small text-center text-md-start">
                @Res.GetString("ShowingXToYOfZ", (CurrentPage - 1) * PageSize + 1, Math.Min(CurrentPage * PageSize, TotalItems), TotalItems)
            </div>
            
            <div class="col-12 col-md-auto">
                <div class="d-flex align-items-center justify-content-center gap-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted">Rows:</span>
                        <select class="form-select form-select-sm border-0 bg-white shadow-sm" style="width: 70px;" 
                                value="@PageSize" @onchange="OnPageSizeChanged">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0 gap-1">
                            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                                <button class="page-link border-0 rounded shadow-sm" @onclick="() => GoToPage(CurrentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                            
                            @foreach (var p in GetPageNumbers())
                            {
                                if (p == -1)
                                {
                                    <li class="page-item disabled"><span class="page-link border-0 bg-transparent">...</span></li>
                                }
                                else
                                {
                                    <li class="page-item @(CurrentPage == p ? "active" : "")">
                                        <button class="page-link border-0 rounded shadow-sm" @onclick="() => GoToPage(p)">@p</button>
                                    </li>
                                }
                            }

                            <li class="page-item @(CurrentPage == (TotalPages == 0 ? 1 : TotalPages) ? "disabled" : "")">
                                <button class="page-link border-0 rounded shadow-sm" @onclick="() => GoToPage(CurrentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .page-link { color: var(--slate-600); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; }
    .page-item.active .page-link { background-color: var(--primary) !important; color: white !important; }
    .page-link:hover:not(.active) { background-color: var(--slate-100); }
    
    /* Selection Highlight */
    .table-active-selection {
        background-color: #f8fafc !important; /* Soft Slate */
    }
    .table-active-selection td {
        background-color: #f8fafc !important;
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "bi-list-stars";
    [Parameter] public List<TItem> Items { get; set; } = new();
    [Parameter] public List<UiGridColumn<TItem>> Columns { get; set; } = new();
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public bool ShowHeader { get; set; } = true;
    
    [Parameter] public bool ShowAddButton { get; set; } = false;
    [Parameter] public string? AddButtonText { get; set; }
    [Parameter] public EventCallback OnAddClick { get; set; }

    [Parameter] public bool ShowSelection { get; set; } = false;
    [Parameter] public bool ShowDeleteButton { get; set; } = false;
    [Parameter] public HashSet<TItem> SelectedItems { get; set; } = new();
    [Parameter] public EventCallback<HashSet<TItem>> SelectedItemsChanged { get; set; }
    [Parameter] public EventCallback<HashSet<TItem>> OnDeleteSelected { get; set; }
    
    [Parameter] public string? DeleteSpName { get; set; }
    [Parameter] public string? IdFieldName { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private Dictionary<string, string> _columnFilters = new();
    private int CurrentPage { get; set; } = 1;
    private string? _sortField;
    private bool _sortDescending;

    private IEnumerable<TItem> FilteredItems
    {
        get
        {
            var data = Items.AsEnumerable();

            // Column filters
            foreach (var filter in _columnFilters)
            {
                if (!string.IsNullOrWhiteSpace(filter.Value))
                {
                    var col = Columns.FirstOrDefault(c => c.FieldName == filter.Key);
                    if (col == null) continue;

                    data = data.Where(i => {
                        var rawVal = GetPropertyValue(i, filter.Key);
                        var valStr = rawVal?.ToString() ?? "";

                        if (col.FilterType == UiGridFilterType.Dropdown)
                        {
                            return valStr.Equals(filter.Value, StringComparison.OrdinalIgnoreCase);
                        }
                        
                        if (col.FilterType == UiGridFilterType.Date)
                        {
                            if (DateTime.TryParse(filter.Value, out var filterDate))
                            {
                                if (rawVal is DateTime dt) return dt.Date == filterDate.Date;
                                
                                if (DateTime.TryParseExact(valStr, "dd/MM/yyyy", null, DateTimeStyles.None, out var itemDate))
                                {
                                    return itemDate.Date == filterDate.Date;
                                }
                                if (DateTime.TryParse(valStr, out var fallbackDate))
                                {
                                    return fallbackDate.Date == filterDate.Date;
                                }
                            }
                            return false;
                        }

                        return valStr.Contains(filter.Value, StringComparison.OrdinalIgnoreCase);
                    });
                }
            }

            // Sorting
            if (!string.IsNullOrEmpty(_sortField))
            {
                var col = Columns.FirstOrDefault(c => c.FieldName == _sortField);
                if (col != null)
                {
                    data = _sortDescending 
                        ? data.OrderByDescending(i => GetPropertyValue(i, _sortField))
                        : data.OrderBy(i => GetPropertyValue(i, _sortField));
                }
            }

            return data;
        }
    }

    private int TotalItems => FilteredItems.Count();
    private int TotalPages => (int)Math.Ceiling((double)TotalItems / PageSize);

    private IEnumerable<TItem> PagedItems => FilteredItems
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize);

    private void GoToPage(int page) => CurrentPage = Math.Clamp(page, 1, TotalPages == 0 ? 1 : TotalPages);

    private void HandleSort(UiGridColumn<TItem> col)
    {
        if (!col.Sortable || string.IsNullOrEmpty(col.FieldName)) return;

        if (_sortField == col.FieldName)
        {
            if (!_sortDescending) _sortDescending = true;
            else _sortField = null; // Reset sort
        }
        else
        {
            _sortField = col.FieldName;
            _sortDescending = false;
        }
        StateHasChanged();
    }

    private bool IsAllSelected => PagedItems.Any() && PagedItems.All(i => SelectedItems.Contains(i));

    private async Task ToggleSelectAll(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        foreach (var item in PagedItems)
        {
            if (isChecked) SelectedItems.Add(item);
            else SelectedItems.Remove(item);
        }
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
    }

    private async Task ToggleSelection(TItem item)
    {
        if (SelectedItems.Contains(item)) SelectedItems.Remove(item);
        else SelectedItems.Add(item);
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            PageSize = size;
            CurrentPage = 1;
        }
    }

    private List<int> GetPageNumbers()
    {
        var numbers = new List<int>();
        if (TotalPages <= 7)
        {
            for (int i = 1; i <= TotalPages; i++) numbers.Add(i);
        }
        else
        {
            numbers.Add(1);
            if (CurrentPage > 4) numbers.Add(-1);
            
            var start = Math.Max(2, CurrentPage - 2);
            var end = Math.Min(TotalPages - 1, CurrentPage + 2);
            for (int i = start; i <= end; i++) numbers.Add(i);

            if (CurrentPage < TotalPages - 3) numbers.Add(-1);
            numbers.Add(TotalPages);
        }
        return numbers;
    }

    private string GetFilterValue(string field) => _columnFilters.TryGetValue(field, out var val) ? val : "";

    private void SetFilterValue(string field, string? value)
    {
        _columnFilters[field] = value ?? "";
        CurrentPage = 1;
    }

    private List<string> GetDistinctValues(string fieldName)
    {
        if (string.IsNullOrEmpty(fieldName) || Items == null) return new();
        return Items.Select(i => GetPropertyValue(i, fieldName)?.ToString() ?? "")
                    .Where(s => !string.IsNullOrEmpty(s))
                    .Distinct()
                    .OrderBy(s => s)
                    .ToList();
    }

    private object? GetPropertyValue(TItem item, string? fieldName)
    {
        if (string.IsNullOrEmpty(fieldName)) return null;
        return item?.GetType().GetProperty(fieldName)?.GetValue(item);
    }

    private async Task HandleDeleteSelected()
    {
        if (string.IsNullOrEmpty(DeleteSpName) || string.IsNullOrEmpty(IdFieldName))
        {
            await OnDeleteSelected.InvokeAsync(SelectedItems);
            return;
        }

        if (SelectedItems == null || !SelectedItems.Any()) return;

        int successCount = 0;
        int errorCount = 0;

        foreach (var item in SelectedItems.ToList())
        {
            var idVal = GetPropertyValue(item, IdFieldName);
            if (idVal == null) continue;

            var param = new Dictionary<string, object> { { IdFieldName, idVal } };
            var res = await DataService.PostDataAsync(DeleteSpName, param, showNotification: false);
            
            if (res.Success) successCount++;
            else errorCount++;
        }

        if (successCount > 0) NotificationService.Notify(Res.GetString("BulkDeleteSuccess", successCount), NotificationType.Success);
        if (errorCount > 0) NotificationService.Notify(Res.GetString("BulkDeleteError", errorCount), NotificationType.Error);

        SelectedItems.Clear();
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
        await OnDataChanged.InvokeAsync();
    }
}
