@inherits UiBase
@inject HRMS.Services.WorkflowService.IWorkflowService WorkflowService
@inject IConfiguration Configuration

@if (WorkflowService.IsModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 1060;">
        <div class="modal-dialog modal-xl modal-dialog-centered shadow-lg" role="document">
            <div class="modal-content border-0 rounded-4 overflow-hidden">
                <div class="modal-header bg-light border-bottom px-4 py-3">
                    <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2">
                        <i class="bi bi-diagram-3 text-primary"></i>
                        @WorkflowService.ModalTitle
                    </h5>
                    <button type="button" class="btn-close shadow-none" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 position-relative" style="height: 80vh; background: #f8fafc;">
                    @if (_isLoading)
                    {
                        <div class="position-absolute top-50 start-50 translate-middle text-center z-index-1">
                            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                            <div class="text-muted fw-medium">@Res.Loading<span class="ms-1">...</span></div>
                        </div>
                    }
                    
                    <iframe src="@FullUrl" 
                            class="w-100 h-100 border-0" 
                            @onload="OnFrameLoad"
                            style="opacity: @(_isLoading ? "0" : "1"); transition: opacity 0.2s ease-in-out;">
                    </iframe>
                </div>
                <div class="modal-footer bg-light border-top px-4 py-3">
                    <button type="button" class="btn btn-secondary px-4 rounded-pill fw-bold" @onclick="CloseModal">
                        @Res.Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _isLoading = true;

    private string FullUrl => string.IsNullOrEmpty(Configuration["Workflow:BaseUrl"]) 
        ? "" 
        : $"{Configuration["Workflow:BaseUrl"]}?tid={WorkflowService.CurrentTransactionId}";

    protected override void OnInitialized()
    {
        WorkflowService.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        if (WorkflowService.IsModalVisible) _isLoading = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnFrameLoad()
    {
        _isLoading = false;
        StateHasChanged();
    }

    private void CloseModal()
    {
        WorkflowService.CloseViewer();
    }

    public override void Dispose()
    {
        WorkflowService.OnStateChanged -= HandleStateChanged;
        base.Dispose();
    }
}
