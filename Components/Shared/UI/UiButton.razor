@using HRMS.Components.Shared.UI
@inherits UiBase

<button type="@(IsSubmit ? "submit" : "button")" 
        class="btn-hrms @TypeClass @CssClass" 
        @onclick="OnClick"
        disabled="@(Disabled || Loading)"
        aria-label="@AriaLabel"
        @attributes="AdditionalAttributes">
    @if (Loading)
    {
        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
    }
    else if (!string.IsNullOrEmpty(Icon))
    {
        <UiIcon Name="@Icon" />
    }
    @if (ChildContent != null)
    {
        <span>@ChildContent</span>
    }
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public string Type { get; set; } = "primary"; 
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string AriaLabel { get; set; } = "";
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool IsSubmit { get; set; } = false;
    [Parameter] public bool Loading { get; set; } = false;
    [Parameter(CaptureUnmatchedValues = true)] public IDictionary<string, object>? AdditionalAttributes { get; set; }

    private string TypeClass => Type.ToLower() switch
    {
        "primary" => "btn-hrms-primary",
        "danger" => "btn-danger",
        "success" => "btn-success",
        "secondary" => "btn-secondary",
        "light" => "btn-light border",
        _ => "btn-secondary"
    };
}
