@typeparam TItem
@using System.Reflection

<div class="card-hrms overflow-hidden">
    <div class="p-3 border-bottom bg-light bg-opacity-10">
        <div class="row align-items-center g-2">
            <div class="col">
                <div class="small-label opacity-75">@Title</div>
            </div>
            <div class="col-auto">
                <div style="width: 220px;">
                    <UiInput Placeholder="@Res.GetString("Search")" 
                             @bind-Value="SearchText" 
                             Icon="bi-search" 
                             CssClass="mb-0" />
                </div>
            </div>
            <div class="col-auto">
                @HeaderContent
            </div>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table-hrms">
            <thead>
                <tr>
                    @foreach (var col in Columns)
                    {
                        <th>@col.Title</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (PagedItems != null && PagedItems.Any())
                {
                    @foreach (var item in PagedItems)
                    {
                        <tr>
                            @foreach (var col in Columns)
                            {
                                <td>
                                    @if (col.Template != null)
                                    {
                                        @col.Template(item)
                                    }
                                    else
                                    {
                                        @GetPropertyValue(item, col.FieldName)
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@Columns.Count" class="text-center py-5">
                            <span class="text-muted small">@Res.GetString("NoRecordsFound")</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="p-3 border-top">
        <div class="row align-items-center">
            <div class="col text-muted small">
                @Res.GetString("ShowingXToYOfZ", (CurrentPage - 1) * PageSize + 1, Math.Min(CurrentPage * PageSize, TotalItems), TotalItems)
            </div>
            <div class="col-auto">
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-light border @(CurrentPage == 1 ? "disabled" : "")" @onclick="PrevPage">
                        <UiIcon Name="chevron-left" CssClass="small" />
                    </button>
                    <button class="btn btn-sm btn-light border @(CurrentPage == TotalPages ? "disabled" : "")" @onclick="NextPage">
                        <UiIcon Name="chevron-right" CssClass="small" />
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<TItem> Items { get; set; } = new();
    [Parameter] public List<GridColumn<TItem>> Columns { get; set; } = new();
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;

    private string _searchText = "";
    private string SearchText 
    { 
        get => _searchText; 
        set { _searchText = value; CurrentPage = 1; } 
    }

    private int CurrentPage { get; set; } = 1;

    private IEnumerable<TItem> FilteredItems => string.IsNullOrWhiteSpace(SearchText) 
        ? Items 
        : Items.Where(i => GetItemString(i).Contains(SearchText, StringComparison.OrdinalIgnoreCase));

    private int TotalItems => FilteredItems.Count();
    private int TotalPages => (int)Math.Ceiling((double)TotalItems / PageSize);

    private IEnumerable<TItem> PagedItems => FilteredItems
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize);

    private void NextPage() => CurrentPage = Math.Min(CurrentPage + 1, TotalPages);
    private void PrevPage() => CurrentPage = Math.Max(CurrentPage - 1, 1);

    private object? GetPropertyValue(TItem item, string? fieldName)
    {
        if (string.IsNullOrEmpty(fieldName)) return null;
        return item?.GetType().GetProperty(fieldName)?.GetValue(item);
    }

    private string GetItemString(TItem item)
    {
        // Simple search logic: concat all property values
        return string.Join(" ", item?.GetType().GetProperties().Select(p => p.GetValue(item)?.ToString() ?? "") ?? Array.Empty<string>());
    }
}
