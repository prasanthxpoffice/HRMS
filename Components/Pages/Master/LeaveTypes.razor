@page "/leavetypes"
@inherits UiBase
@rendermode InteractiveServer
@inject IDataService DataService

<UiGrid @ref="grid"
        TItem="HRMS.Models.Master.LeaveType" 
        Title="@Res.GetString("LeaveType_GridTitle")" 
        Items="Items" 
        Columns="columns" 
        ShowAddButton="true" 
        AddButtonText="@Res.GetString("LeaveType_Add")" 
        OnAddClick="() => Prepare()"
        ShowSelection="true"
        ShowDeleteButton="true"
        DeleteSpName="@StoredProcedure.HRMSDB.Master.spLeaveTypeDelete"
        DeleteConnectionName="@ConnectionNames.Default"
        IdFieldName="LeaveTypeId"
        OnDataChanged="LoadData"
        ShowWorkflow="true"
        ShowExport="true"
        OnGetExportData="GetExportData"
        ExportName="LeaveType"
        Loading="IsLoading" />
 
<UiModal Show="ShowModal" Title="@(CurrentItem.LeaveTypeId == 0 ? Res.GetString("LeaveType_Add") : Res.Edit)" OnClose="CloseModal">
    <Body>
        <EditForm id="leaveTypeForm" Model="CurrentItem" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <UiInput Label="@Res.NameEn" @bind-Value="CurrentItem.LeaveTypeEn" Placeholder="@Res.NameEn" />
            <ValidationMessage For="@(() => CurrentItem.LeaveTypeEn)" />

            <UiInput Label="@Res.NameAr" @bind-Value="CurrentItem.LeaveTypeAr" Placeholder="@Res.NameAr" IsRtl="true" />
            <ValidationMessage For="@(() => CurrentItem.LeaveTypeAr)" />
        </EditForm>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="CloseModal" Disabled="IsSaving">@Res.Cancel</UiButton>
        <UiButton IsSubmit="true" form="leaveTypeForm" Loading="IsSaving">@Res.Save</UiButton>
    </Footer>
</UiModal>

@code {
    private List<HRMS.Models.Master.LeaveType> Items = new();
    private HRMS.Models.Master.LeaveType CurrentItem = new();
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;
    private UiGrid<HRMS.Models.Master.LeaveType> grid = default!;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadData();
    }

    private Task LoadData() => LoadAsync(async () => 
    {
        Items = await DataService.GetListAsync<HRMS.Models.Master.LeaveType>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spLeaveTypeGet, new { });
    });
    
    private Task<IEnumerable<object>> GetExportData() => Task.FromResult<IEnumerable<object>>(Items.Cast<object>());

    private List<UiGridColumn<HRMS.Models.Master.LeaveType>> columns => new()
    {
        new UiGridColumn<HRMS.Models.Master.LeaveType> { Title = Res.Id, FieldName = "LeaveTypeId" },
        new UiGridColumn<HRMS.Models.Master.LeaveType> { Title = Res.NameEn, FieldName = "LeaveTypeEn" },
        new UiGridColumn<HRMS.Models.Master.LeaveType> { Title = Res.NameAr, FieldName = "LeaveTypeAr",  FilterType = UiGridFilterType.Dropdown },
        new UiGridColumn<HRMS.Models.Master.LeaveType> { Title = Res.CreatedDate, FieldName = "CreatedDate", FilterType = UiGridFilterType.Date },
        new UiGridColumn<HRMS.Models.Master.LeaveType> { Title = Res.Actions, Template = (item) => @<UiGridActions OnEdit="() => Prepare(item)" 
                                                                                             OnDelete="() => grid.RequestDelete(item)" /> }
    };

    private async Task Prepare(HRMS.Models.Master.LeaveType? item = null)
    {
        if (item == null)
        {
            CurrentItem = new HRMS.Models.Master.LeaveType { LeaveTypeId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<HRMS.Models.Master.LeaveType>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spLeaveTypeGet, new { LeaveTypeId = item.LeaveTypeId });
            CurrentItem = result?.FirstOrDefault() ?? new HRMS.Models.Master.LeaveType();
        }
        ShowModal = true;
    }  

    private async Task Save()
    {
        var res = await DataService.PostDataAsync(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spLeaveTypeSave, CurrentItem);
        if (res.Success == 1)
        {
            ShowModal = false;
            await LoadData();
        }
    }
}
