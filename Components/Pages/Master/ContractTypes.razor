@page "/contracttypes"
@inherits UiBase
@rendermode InteractiveServer
@inject IDataService DataService

<UiGrid @ref="grid"
        TItem="HRMS.Models.Master.ContractType" 
        Title="@AppResources.ContractType_GridTitle" 
        Items="Items" 
        Columns="columns" 
        ShowAddButton="true" 
        AddButtonText="@AppResources.ContractType_Add" 
        OnAddClick="() => Prepare()"
        ShowSelection="true"
        ShowDeleteButton="true"
        DeleteSpName="@StoredProcedure.HRMSDB.Master.spContractTypeDelete"
        DeleteConnectionName="@ConnectionNames.Default"
        IdFieldName="ContractId"
        OnDataChanged="LoadData"
        ShowWorkflow="true"
        ShowExport="true"
        OnGetExportData="GetExportData"
        ExportName="ContractType"
        Loading="IsLoading" />
 
<UiModal Show="ShowModal" Title="@(CurrentItem.ContractId == 0 ? AppResources.ContractType_Add : AppResources.Edit)" OnClose="CloseModal">
    <Body>
        <EditForm id="contractTypeForm" Model="CurrentItem" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <UiInput Label="@AppResources.NameEn" @bind-Value="CurrentItem.ContractNameEn" Placeholder="@AppResources.NameEn" />
            <ValidationMessage For="@(() => CurrentItem.ContractNameEn)" />

            <UiInput Label="@AppResources.NameAr" @bind-Value="CurrentItem.ContractNameAr" Placeholder="@AppResources.NameAr" IsRtl="true" />
            <ValidationMessage For="@(() => CurrentItem.ContractNameAr)" />
        </EditForm>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="CloseModal" Disabled="IsSaving">@AppResources.Cancel</UiButton>
        <UiButton IsSubmit="true" form="contractTypeForm" Loading="IsSaving">@AppResources.Save</UiButton>
    </Footer>
</UiModal>

@code {
    private List<HRMS.Models.Master.ContractType> Items = new();
    private HRMS.Models.Master.ContractType CurrentItem = new();
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;
    private UiGrid<HRMS.Models.Master.ContractType> grid = default!;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadData();
    }

    private Task LoadData() => LoadAsync(async () => 
    {
        Items = await DataService.GetListAsync<HRMS.Models.Master.ContractType>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spContractTypeGet, new { });
    });
    
    private Task<IEnumerable<object>> GetExportData() => Task.FromResult<IEnumerable<object>>(Items.Cast<object>());

    private List<UiGridColumn<HRMS.Models.Master.ContractType>> columns => new()
    {
        new UiGridColumn<HRMS.Models.Master.ContractType> { Title = AppResources.Id, FieldName = "ContractId" },
        new UiGridColumn<HRMS.Models.Master.ContractType> { Title = AppResources.NameEn, FieldName = "ContractNameEn" },
        new UiGridColumn<HRMS.Models.Master.ContractType> { Title = AppResources.NameAr, FieldName = "ContractNameAr",  FilterType = UiGridFilterType.Dropdown },
        new UiGridColumn<HRMS.Models.Master.ContractType> { Title = AppResources.CreatedDate, FieldName = "CreatedDate", FilterType = UiGridFilterType.Date },
        new UiGridColumn<HRMS.Models.Master.ContractType> { Title = AppResources.Actions, Template = (item) => @<UiGridActions OnEdit="() => Prepare(item)" 
                                                                                             OnDelete="() => grid.RequestDelete(item)" /> }
    };

    private async Task Prepare(HRMS.Models.Master.ContractType? item = null)
    {
        if (item == null)
        {
            CurrentItem = new HRMS.Models.Master.ContractType { ContractId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<HRMS.Models.Master.ContractType>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spContractTypeGet, new { ContractId = item.ContractId });
            CurrentItem = result?.FirstOrDefault() ?? new HRMS.Models.Master.ContractType();
        }
        ShowModal = true;
    }  

    private async Task Save()
    {
        var res = await DataService.PostDataAsync(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spContractTypeSave, CurrentItem);
        if (res.Success == 1)
        {
            ShowModal = false;
            await LoadData();
        }
    }
}
