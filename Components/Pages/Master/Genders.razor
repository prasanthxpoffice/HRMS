@page "/genders"
@rendermode InteractiveServer
@using HRMS.Models.Master
@using HRMS.Services
@using Microsoft.AspNetCore.Components.Forms
@inject IDataService DataService
@inject IResourceService Res

<PageTitle>@Res.GetString("PageTitle_Genders")</PageTitle>

<PageHeader Title="@Res.GetString("Gender_Title")" 
            Description="@Res.GetString("Gender_Description")" 
            Icon="bi-gender-ambiguous"
            ButtonText="@Res.GetString("Gender_Add")"
            OnButtonClick="() => Prepare()" />

<Grid TItem="Gender" Title="@Res.GetString("Gender_GridTitle")" Items="Items" Columns="columns" />

<UiModal Show="ShowModal" Title="@(CurrentItem.GenderId == 0 ? Res.GetString("Gender_Add") : Res.GetString("Edit"))" OnClose="CloseModal">
    <Body>
        <EditForm id="genderForm" Model="CurrentItem" OnValidSubmit="HandleSave">
            <DataAnnotationsValidator />
            <UiInput Label="@Res.GetString("NameEn")" @bind-Value="CurrentItem.GenderNameEn" Placeholder="@Res.GetString("NameEn")" />
            <ValidationMessage For="@(() => CurrentItem.GenderNameEn)" />

            <UiInput Label="@Res.GetString("NameAr")" @bind-Value="CurrentItem.GenderNameAr" Placeholder="@Res.GetString("NameAr")" IsRtl="true" />
            <ValidationMessage For="@(() => CurrentItem.GenderNameAr)" />
        </EditForm>
    </Body>
    <Footer>
        <AppButton Type="light" OnClick="CloseModal">@Res.GetString("Cancel")</AppButton>
        <AppButton IsSubmit="true" form="genderForm">@Res.GetString("Save")</AppButton>
    </Footer>
</UiModal>

@code {
    private List<Gender> Items = new();
    private Gender CurrentItem = new();
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        Items = await DataService.GetListAsync<Gender>("master.spGenderGet", new { });
    }
    
    private List<GridColumn<Gender>> columns => new()
    {
        new() { Title = Res.GetString("Id"), FieldName = "GenderId" },
        new() { Title = Res.GetString("NameEn"), FieldName = "GenderNameEn" },
        new() { Title = Res.GetString("NameAr"), FieldName = "GenderNameAr" },
        new() { Title = Res.GetString("Actions"), Template = RenderActions }
    };

    private RenderFragment RenderActions(Gender item) => __builder => {
        <GridActions OnEdit="() => Prepare(item)" 
                     OnDelete="() => Delete(item)" 
                     EditTitle="@Res.GetString("Edit")" 
                     DeleteTitle="@Res.GetString("Delete")" />
    };


    private async Task Prepare(Gender? item = null)
    {
        if (item == null)
        {
            CurrentItem = new Gender { GenderId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<Gender>("master.spGenderGet", new { GenderId = item.GenderId });
            CurrentItem = result?.FirstOrDefault() ?? new Gender();
        }
        ShowModal = true;
    }  

    private async Task HandleSave()
    {
        var res = await DataService.PostDataAsync("master.spGenderSave", CurrentItem);
        if (res.Success)
        {
            ShowModal = false;
            await LoadData();
        }
    }

    private async Task Delete(Gender item)
    {
        var res = await DataService.PostDataAsync("master.spGenderDelete", new { GenderId = item.GenderId });
        if (res.Success) await LoadData();
    }
}
