@page "/genders"
@inherits UiBase
@rendermode InteractiveServer
@inject IDataService DataService

<UiGrid @ref="grid"
        TItem="Gender" 
        Title="@Res.Gender_GridTitle" 
        Items="Items" 
        Columns="columns" 
        ShowAddButton="true" 
        AddButtonText="@Res.Gender_Add" 
        OnAddClick="() => Prepare()"
        ShowSelection="true"
        ShowDeleteButton="true"
        DeleteSpName="master.spGenderDelete"
        IdFieldName="GenderId"
        OnDataChanged="LoadData"
        ShowWorkflow="true"
        Loading="IsLoading" />

<UiModal Show="ShowModal" Title="@(CurrentItem.GenderId == 0 ? Res.Gender_Add : Res.Edit)" OnClose="CloseModal">
    <Body>
        <EditForm id="genderForm" Model="CurrentItem" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <UiInput Label="@Res.NameEn" @bind-Value="CurrentItem.GenderNameEn" Placeholder="@Res.NameEn" />
            <ValidationMessage For="@(() => CurrentItem.GenderNameEn)" />

            <UiInput Label="@Res.NameAr" @bind-Value="CurrentItem.GenderNameAr" Placeholder="@Res.NameAr" IsRtl="true" />
            <ValidationMessage For="@(() => CurrentItem.GenderNameAr)" />
        </EditForm>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="CloseModal" Disabled="IsSaving">@Res.Cancel</UiButton>
        <UiButton IsSubmit="true" form="genderForm" Loading="IsSaving">@Res.Save</UiButton>
    </Footer>
</UiModal>

@code {
    private List<Gender> Items = new();
    private Gender CurrentItem = new();
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;
    private UiGrid<Gender> grid = default!;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadData();
    }

    private Task LoadData() => LoadAsync(async () => 
    {
        Items = await DataService.GetListAsync<Gender>("master.spGenderGet", new { });
    });
    
    private List<UiGridColumn<Gender>> columns => new()
    {
        new UiGridColumn<Gender> { Title = Res.Id, FieldName = "GenderId" },
        new UiGridColumn<Gender> { Title = Res.NameEn, FieldName = "GenderNameEn" },
        new UiGridColumn<Gender> { Title = Res.NameAr, FieldName = "GenderNameAr",  FilterType = UiGridFilterType.Dropdown },
        new UiGridColumn<Gender> { Title = Res.CreatedDate, FieldName = "CreatedDate", FilterType = UiGridFilterType.Date },
        new UiGridColumn<Gender> { Title = Res.Actions, Template = (item) => @<UiGridActions OnEdit="() => Prepare(item)" 
                                                                                             OnDelete="() => grid.RequestDelete(item)" /> }
    };

    private async Task Prepare(Gender? item = null)
    {
        if (item == null)
        {
            CurrentItem = new Gender { GenderId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<Gender>("master.spGenderGet", new { GenderId = item.GenderId });
            CurrentItem = result?.FirstOrDefault() ?? new Gender();
        }
        ShowModal = true;
    }  

    private async Task Save()
    {
        var res = await DataService.PostDataAsync("master.spGenderSave", CurrentItem);
        if (res.Success == 1)
        {
            ShowModal = false;
            await LoadData();
        }
    }
}
