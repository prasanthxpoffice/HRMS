@page "/genders"
@rendermode InteractiveServer
@inject IDataService DataService
@inject IResourceService Res

<PageTitle>@Res.GetString("PageTitle_Genders")</PageTitle>

<UiPageHeader Title="@Res.GetString("Gender_Title")" 
              Description="@Res.GetString("Gender_Subtitle")" 
              Icon="bi-gender-ambiguous">
    <ButtonContent>
        <UiButton Icon="bi-plus-lg" OnClick="() => Prepare()">@Res.GetString("AddGender")</UiButton>
    </ButtonContent>
</UiPageHeader>

<UiGrid TItem="Gender" Title="@Res.GetString("Gender_GridTitle")" Items="Items" Columns="columns" />

<UiModal Show="ShowModal" Title="@(CurrentItem.GenderId == 0 ? Res.GetString("Gender_Add") : Res.GetString("Edit"))" OnClose="CloseModal">
    <Body>
        <EditForm id="genderForm" Model="CurrentItem" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <UiInput Label="@Res.GetString("NameEn")" @bind-Value="CurrentItem.GenderNameEn" Placeholder="@Res.GetString("NameEn")" />
            <ValidationMessage For="@(() => CurrentItem.GenderNameEn)" />

            <UiInput Label="@Res.GetString("NameAr")" @bind-Value="CurrentItem.GenderNameAr" Placeholder="@Res.GetString("NameAr")" IsRtl="true" />
            <ValidationMessage For="@(() => CurrentItem.GenderNameAr)" />
        </EditForm>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="CloseModal">@Res.GetString("Cancel")</UiButton>
        <UiButton IsSubmit="true" form="genderForm">@Res.GetString("Save")</UiButton>
    </Footer>
</UiModal>

@code {
    private List<Gender> Items = new();
    private Gender CurrentItem = new();
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        Items = await DataService.GetListAsync<Gender>("master.spGenderGet", new { });
    }
    
    private List<UiGridColumn<Gender>> columns => new()
    {
        new UiGridColumn<Gender> { Title = Res.GetString("Id"), FieldName = "GenderId" },
        new UiGridColumn<Gender> { Title = Res.GetString("NameEn"), FieldName = "GenderNameEn" },
        new UiGridColumn<Gender> { Title = Res.GetString("NameAr"), FieldName = "GenderNameAr" },
        new UiGridColumn<Gender> { Title = Res.GetString("Actions"), Template = (item) => @<UiGridActions OnEdit="() => Prepare(item)" 
                                                                                        OnDelete="() => Delete(item)" 
                                                                                        EditTitle="@Res.GetString("Edit")" 
                                                                                        DeleteTitle="@Res.GetString("Delete")" /> }
    };


    private async Task Prepare(Gender? item = null)
    {
        if (item == null)
        {
            CurrentItem = new Gender { GenderId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<Gender>("master.spGenderGet", new { GenderId = item.GenderId });
            CurrentItem = result?.FirstOrDefault() ?? new Gender();
        }
        ShowModal = true;
    }  

    private async Task Save()
    {
        var res = await DataService.PostDataAsync("master.spGenderSave", CurrentItem);
        if (res.Success)
        {
            ShowModal = false;
            await LoadData();
        }
    }

    private async Task Delete(Gender item)
    {
        var res = await DataService.PostDataAsync("master.spGenderDelete", new { GenderId = item.GenderId });
        if (res.Success) await LoadData();
    }
}
