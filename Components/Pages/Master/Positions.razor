@page "/positions"
@inherits UiBase
@rendermode InteractiveServer
@inject IDataService DataService

<UiGrid @ref="grid"
        TItem="HRMS.Models.Master.Position" 
        Title="@Res.GetString("Position_GridTitle")" 
        Items="Items" 
        Columns="columns" 
        ShowAddButton="true" 
        AddButtonText="@Res.GetString("Position_Add")" 
        OnAddClick="() => Prepare()"
        ShowSelection="true"
        ShowDeleteButton="true"
        DeleteSpName="@StoredProcedure.HRMSDB.Master.spPositionDelete"
        DeleteConnectionName="@ConnectionNames.Default"
        IdFieldName="PositionId"
        OnDataChanged="LoadData"
        ShowWorkflow="true"
        ShowExport="true"
        OnGetExportData="GetExportData"
        ExportName="Position"
        Loading="IsLoading" />
 
<UiModal Show="ShowModal" Title="@(CurrentItem.PositionId == 0 ? Res.GetString("Position_Add") : Res.Edit)" OnClose="CloseModal">
    <Body>
        <EditForm id="positionForm" Model="CurrentItem" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <UiInput Label="@Res.NameEn" @bind-Value="CurrentItem.PositionNameEn" Placeholder="@Res.NameEn" />
            <ValidationMessage For="@(() => CurrentItem.PositionNameEn)" />

            <UiInput Label="@Res.NameAr" @bind-Value="CurrentItem.PositionNameAr" Placeholder="@Res.NameAr" IsRtl="true" />
            <ValidationMessage For="@(() => CurrentItem.PositionNameAr)" />
        </EditForm>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="CloseModal" Disabled="IsSaving">@Res.Cancel</UiButton>
        <UiButton IsSubmit="true" form="positionForm" Loading="IsSaving">@Res.Save</UiButton>
    </Footer>
</UiModal>

@code {
    private List<HRMS.Models.Master.Position> Items = new();
    private HRMS.Models.Master.Position CurrentItem = new();
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;
    private UiGrid<HRMS.Models.Master.Position> grid = default!;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadData();
    }

    private Task LoadData() => LoadAsync(async () => 
    {
        Items = await DataService.GetListAsync<HRMS.Models.Master.Position>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spPositionGet, new { });
    });
    
    private Task<IEnumerable<object>> GetExportData() => Task.FromResult<IEnumerable<object>>(Items.Cast<object>());

    private List<UiGridColumn<HRMS.Models.Master.Position>> columns => new()
    {
        new UiGridColumn<HRMS.Models.Master.Position> { Title = Res.Id, FieldName = "PositionId" },
        new UiGridColumn<HRMS.Models.Master.Position> { Title = Res.NameEn, FieldName = "PositionNameEn" },
        new UiGridColumn<HRMS.Models.Master.Position> { Title = Res.NameAr, FieldName = "PositionNameAr",  FilterType = UiGridFilterType.Dropdown },
        new UiGridColumn<HRMS.Models.Master.Position> { Title = Res.CreatedDate, FieldName = "CreatedDate", FilterType = UiGridFilterType.Date },
        new UiGridColumn<HRMS.Models.Master.Position> { Title = Res.Actions, Template = (item) => @<UiGridActions OnEdit="() => Prepare(item)" 
                                                                                             OnDelete="() => grid.RequestDelete(item)" /> }
    };

    private async Task Prepare(HRMS.Models.Master.Position? item = null)
    {
        if (item == null)
        {
            CurrentItem = new HRMS.Models.Master.Position { PositionId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<HRMS.Models.Master.Position>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spPositionGet, new { PositionId = item.PositionId });
            CurrentItem = result?.FirstOrDefault() ?? new HRMS.Models.Master.Position();
        }
        ShowModal = true;
    }  

    private async Task Save()
    {
        var res = await DataService.PostDataAsync(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spPositionSave, CurrentItem);
        if (res.Success == 1)
        {
            ShowModal = false;
            await LoadData();
        }
    }
}
