@using HRMS.Resources

<div class="leave-policy-container">
    <div class="alert alert-info shadow-sm border-0 rounded-3 mb-4">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-info-circle-fill fs-5"></i>
            <h6 class="mb-0 fw-bold">@AppResources.LeavePolicy</h6>
        </div>
        <p class="mb-0 small opacity-75">
            This page will display the policy details for the selected leave contract positions.
        </p>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4 text-center">
            <div class="mb-3">
                <i class="bi bi-file-earmark-text display-4 text-primary opacity-25"></i>
            </div>
            <h5 class="h6 fw-bold mb-3 text-uppercase opacity-75" style="letter-spacing: 0.1em;">Selected Identifiers</h5>
            <div class="p-3 bg-light rounded-3 font-monospace small border">
                @if (string.IsNullOrEmpty(SelectedIds))
                {
                    <span class="text-muted">No IDs passed.</span>
                }
                else
                {
                    <span class="text-primary fw-bold">@SelectedIds</span>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? SelectedIds { get; set; }
}
