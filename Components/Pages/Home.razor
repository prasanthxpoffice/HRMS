@page "/"
@inherits UiBase
@using HRMS.Components.Pages.Dashboard

<div class="dashboard-hero mb-4 p-3 p-md-4 rounded-4 shadow-sm border-0 position-relative overflow-hidden" 
     style="background: linear-gradient(135deg, var(--uae-bronze) 0%, var(--uae-sand) 100%); color: white;">
    <div class="position-relative z-1">
        <div class="small-label text-white text-opacity-75 mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">@AppResources.WelcomeBack</div>
        <h2 class="fw-bold mb-1">
            @AppResources.WelcomeUser @(UserService.CurrentUser?.UserName ?? "Admin")
        </h2>
        <p class="mb-0 text-white text-opacity-90 small" style="max-width: 600px;">
            @AppResources.DashboardSummary
        </p>
    </div>
    
 
</div>

@if (UserService.CurrentRole?.RoleName == "Administrator")
{
    <AdminDashboard />
}
else
{
    <EmployeeDashboard />
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await Task.CompletedTask;
    }
}

<style>
    .dashboard-hero {
        min-height: 140px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
</style>