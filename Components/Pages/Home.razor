@page "/"
@inherits UiBase

<div class="row g-4">
    <div class="col-12 col-xl-8">
        <div class="card-hrms p-5 bg-white border-0" style="background: linear-gradient(to right, #ffffff, #f8fafc);">
            <div class="small-label text-primary mb-2">@Res.WelcomeBack</div>
            <h1 class="header-title mb-3" style="font-size: 2.5rem;">@Res.SystemDashboard</h1>
            <p class="text-muted mb-4" style="max-width: 500px;">
                @Res.DashboardDescription
            </p>
            <div class="d-flex gap-2">
                <a href="genders" class="btn-hrms btn-hrms-primary px-4">
                    <UiIcon Name="people" />
                    @Res.ManageGenders
                </a>
                <button class="btn btn-sm btn-light border px-4">
                    <UiIcon Name="gear" />
                    @Res.Settings
                </button>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-xl-4">
        <div class="card-hrms p-4 h-100">
            <div class="small-label mb-3">@Res.SystemStatus</div>
            <div class="d-flex align-items-center mb-3">
                <div class="rounded-circle bg-success me-2" style="width: 8px; height: 8px;"></div>
                <div class="small fw-medium">@Res.DatabaseConnected</div>
            </div>
            <div class="d-flex align-items-center mb-3">
                <div class="rounded-circle bg-success me-2" style="width: 8px; height: 8px;"></div>
                <div class="small fw-medium">@Res.AuthenticationActive</div>
            </div>
        </div>
    </div>
</div>