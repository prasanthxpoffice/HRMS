@inherits UiBase
@rendermode InteractiveServer
@inject IDataService DataService

@using HRMS.Models.Admin
@using HRMS.Models.Master
@using HRMS.Models.Shared

<UiGrid @ref="grid"
        TItem="CompanyContract" 
        Title="@AppResources.CompanyContract_GridTitle" 
        Items="Items" 
        Columns="columns" 
        ShowAddButton="true" 
        AddButtonText="@AppResources.CompanyContract_Add" 
        OnAddClick="() => Prepare()"
        ShowSelection="true"
        ShowDeleteButton="true"
        DeleteSpName="@StoredProcedure.HRMSDB.Admin.spCompanyContractDelete"
        DeleteConnectionName="@ConnectionNames.Default"
        IdFieldName="CompanyContractId"
        OnDataChanged="LoadData"
        ShowWorkflow="true"
        ShowExport="true"
        OnGetExportData="GetExportData"
        ExportName="CompanyContracts"
        Loading="IsLoading" />
 
<UiModal Show="ShowModal" Title="@(CurrentItem.CompanyContractId == 0 ? AppResources.CompanyContract_Add : AppResources.Edit)" OnClose="CloseModal">
    <Body>
        <EditForm id="companyContractForm" Model="CurrentItem" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            
            <div class="mb-3">
                <UiSelect Label="@AppResources.Company" 
                          Items="Lookups.Companies"
                          Placeholder="@AppResources.SelectCompany"
                          @bind-Value="CurrentItem.CompanyId" />
                <ValidationMessage For="@(() => CurrentItem.CompanyId)" />
            </div>

            <div class="mb-3">
                <UiSelect Label="@AppResources.ContractType" 
                          Items="Lookups.ContractTypes"
                          Placeholder="@AppResources.SelectContract"
                          @bind-Value="CurrentItem.ContractId" />
                <ValidationMessage For="@(() => CurrentItem.ContractId)" />
            </div>

        </EditForm>
    </Body>
    <Footer>
        <UiButton Type="light" OnClick="CloseModal" Disabled="IsSaving">@AppResources.Cancel</UiButton>
        <UiButton IsSubmit="true" form="companyContractForm" Loading="IsSaving">@AppResources.Save</UiButton>
    </Footer>
</UiModal>

@code {
    private List<CompanyContract> Items = new();
    private CompanyContract CurrentItem = new();
    
    // Lookup caches for Dropdowns
    private (List<LookupItem> Companies, List<LookupItem> ContractTypes) Lookups = (new(), new());
    
    private bool ShowModal = false;
    private void CloseModal() => ShowModal = false;
    private UiGrid<CompanyContract> grid = default!;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadData();
        await LoadLookups();
    }

    private Task LoadData() => LoadAsync(async () => 
    {
        Items = await DataService.GetListAsync<CompanyContract>(ConnectionNames.Default, StoredProcedure.HRMSDB.Admin.spCompanyContractGet, new { });
    });
    
    private async Task LoadLookups()
    {
        var companies = await DataService.GetListAsync<Company>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spCompanyGet, new { });
        Lookups.Companies = companies.Select(c => new LookupItem { Id = c.CompanyId.ToString(), Name = c.CompanyName ?? "" }).ToList();
        
        var contracts = await DataService.GetListAsync<ContractType>(ConnectionNames.Default, StoredProcedure.HRMSDB.Master.spContractTypeGet, new { });
        Lookups.ContractTypes = contracts.Select(c => new LookupItem { Id = c.ContractId.ToString(), Name = c.ContractName ?? "" }).ToList();
    }

    private Task<IEnumerable<object>> GetExportData() => Task.FromResult<IEnumerable<object>>(Items.Cast<object>());

    private List<UiGridColumn<CompanyContract>> columns => new()
    {
        new UiGridColumn<CompanyContract> { Title = AppResources.Id, FieldName = "CompanyContractId" },
        new UiGridColumn<CompanyContract> { Title = AppResources.Company, FieldName = "CompanyName", FilterType = UiGridFilterType.Dropdown },
        new UiGridColumn<CompanyContract> { Title = AppResources.ContractType, FieldName = "ContractName", FilterType = UiGridFilterType.Dropdown },
        new UiGridColumn<CompanyContract> { Title = AppResources.CreatedDate, FieldName = "CreatedDate", FilterType = UiGridFilterType.Date },
        new UiGridColumn<CompanyContract> { Title = AppResources.Actions, Template = (item) => @<UiGridActions OnDelete="() => grid.RequestDelete(item)" /> }
    };

    private async Task Prepare(CompanyContract? item = null)
    {
        if (item == null)
        {
            CurrentItem = new CompanyContract { CompanyContractId = 0 };
        }
        else
        {
            var result = await DataService.GetListAsync<CompanyContract>(ConnectionNames.Default, StoredProcedure.HRMSDB.Admin.spCompanyContractGet, new { CompanyContractId = item.CompanyContractId });
            CurrentItem = result?.FirstOrDefault() ?? new CompanyContract();
        }
        ShowModal = true;
    }  

    private async Task Save()
    {
        var res = await DataService.PostDataAsync(ConnectionNames.Default, StoredProcedure.HRMSDB.Admin.spCompanyContractSave, CurrentItem);
        if (res.Success == 1)
        {
            ShowModal = false;
            await LoadData();
        }
    }
}
