@inherits UiBase
@rendermode InteractiveServer
@inject IDataService DataService

@using HRMS.Models.Admin
@using HRMS.Models.Shared

<UiGrid @ref="grid"
        TItem="LeaveContractPosition" 
        Title="@AppResources.LeaveContractPosition_GridTitle" 
        Items="Items" 
        Columns="columns" 
        ShowAddButton="false" 
        ShowSelection="true"
        ShowDeleteButton="false"
        OnDataChanged="LoadData"
        ShowExport="true"
        OnGetExportData="GetExportData"
        ExportName="LeaveContractPositions"
        SelectedIds="_selectedIds"
        IdFieldName="LeaveContractPositionId"
        Loading="IsLoading">
    <HeaderContent>
        <UiButton Type="light" Icon="bi-journal-text" OnClick="OnLeavePolicyClick" CssClass="btn-sm" Disabled="@(!_selectedIds.Any())">
            @AppResources.LeavePolicy
        </UiButton>
    </HeaderContent>
</UiGrid>

<UiModal Show="_showPolicyModal" Title="@AppResources.LeavePolicy" Size="ModalSize.Large" OnClose="() => _showPolicyModal = false">
    <Body>
        <HRMS.Components.Pages.Policy.LeavePolicyDialog SelectedIds="@_selectedIdsString" 
                                                         OnSaved="HandlePolicySaved" 
                                                         OnCancel="() => _showPolicyModal = false" />
    </Body>
</UiModal>

@code {
    private UiGrid<LeaveContractPosition>? grid;
    private List<LeaveContractPosition> Items = new();
    private HashSet<object> _selectedIds = new();
    private bool _showPolicyModal;
    private string _selectedIdsString = "";

    private List<UiGridColumn<LeaveContractPosition>> columns => new()
    {
        new UiGridColumn<LeaveContractPosition> { FieldName = nameof(LeaveContractPosition.LeaveTypeName), Title = AppResources.LeaveType, FilterType = UiGridFilterType.Dropdown},
        new UiGridColumn<LeaveContractPosition> { FieldName = nameof(LeaveContractPosition.CompanyName), Title = AppResources.Company, FilterType=UiGridFilterType.Dropdown },
        new UiGridColumn<LeaveContractPosition> { FieldName = nameof(LeaveContractPosition.ContractName), Title = AppResources.ContractType, FilterType=UiGridFilterType.Dropdown },
        new UiGridColumn<LeaveContractPosition> { FieldName = nameof(LeaveContractPosition.PositionName), Title = AppResources.Position, FilterType=UiGridFilterType.Dropdown }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private Task LoadData() => LoadAsync(async () =>
    {
        Items = await DataService.GetListAsync<LeaveContractPosition>(
            ConnectionNames.Default,
            StoredProcedure.HRMSDB.Admin.spLeaveContractPositionGet,
            new { LeaveContractPositionId = 0 }
        );
    });

    private Task<IEnumerable<object>> GetExportData()
    {
        return Task.FromResult<IEnumerable<object>>(Items.Cast<object>());
    }

    private void OnLeavePolicyClick()
    {
        if (_selectedIds.Any())
        {
            _selectedIdsString = string.Join(",", _selectedIds);
            _showPolicyModal = true;
        }
    }

    private async Task HandlePolicySaved()
    {
        _showPolicyModal = false;
        _selectedIds.Clear();
        await LoadData();
    }
}
